{
  "name": "woxa-vault-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Woxa Secret Vault backend (Hono + Drizzle + Lucia v3)",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --import tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx src/db/seed.ts",
    "dev:pg": "tsx scripts/dev-pg.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "@node-rs/argon2": "^2.0.2",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "bip39": "^3.1.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "ioredis": "^5.11.0",
    "otplib": "^12.0.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "resend": "^4.0.1",
    "uuidv7": "^1.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.5",
    "drizzle-kit": "^0.30.1",
    "embedded-postgres": "^18.3.0-beta.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "optionalDependencies": {
    "@embedded-postgres/darwin-arm64": "^18.3.0-beta.17"
  }
}
